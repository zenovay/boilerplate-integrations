{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node", "vitest/globals"]
  },
  "include": ["packages/**/*.ts", "vitest.config.ts"],
  "exclude": ["**/dist/**", "**/.next/**", "**/.nuxt/**", "**/.svelte-kit/**"]
}

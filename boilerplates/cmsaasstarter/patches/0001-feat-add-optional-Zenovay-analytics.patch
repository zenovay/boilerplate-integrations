diff --git a/src/routes/(admin)/account/+layout.svelte b/src/routes/(admin)/account/+layout.svelte
index 5ff9818..8d221e0 100644
--- a/src/routes/(admin)/account/+layout.svelte
+++ b/src/routes/(admin)/account/+layout.svelte
@@ -1,5 +1,6 @@
 <script lang="ts">
   import { invalidate } from "$app/navigation"
+  import { identify } from "@zenovay/tracker"
   import { onMount } from "svelte"
 
   let { data, children } = $props()
@@ -8,13 +9,17 @@
   let session = $derived(data.session)
 
   onMount(() => {
-    const { data } = supabase.auth.onAuthStateChange((event, _session) => {
-      if (_session?.expires_at !== session?.expires_at) {
-        invalidate("supabase:auth")
-      }
-    })
+    identify(data.user.id, { email: data.user.email })
 
-    return () => data.subscription.unsubscribe()
+    const { data: authListener } = supabase.auth.onAuthStateChange(
+      (event, _session) => {
+        if (_session?.expires_at !== session?.expires_at) {
+          invalidate("supabase:auth")
+        }
+      },
+    )
+
+    return () => authListener.subscription.unsubscribe()
   })
 </script>
 
diff --git a/src/routes/+layout.svelte b/src/routes/+layout.svelte
index 45621e4..cea3e80 100644
--- a/src/routes/+layout.svelte
+++ b/src/routes/+layout.svelte
@@ -1,6 +1,10 @@
 <script lang="ts">
   import "../app.css"
+  import { browser } from "$app/environment"
+  import { afterNavigate } from "$app/navigation"
   import { navigating } from "$app/stores"
+  import { env } from "$env/dynamic/public"
+  import { init, page } from "@zenovay/tracker"
   import { expoOut } from "svelte/easing"
   import { slide } from "svelte/transition"
   interface Props {
@@ -8,6 +12,19 @@
   }
 
   let { children }: Props = $props()
+
+  let zenovayReady = false
+
+  if (browser && env.PUBLIC_ZENOVAY_TRACKING_CODE) {
+    init(env.PUBLIC_ZENOVAY_TRACKING_CODE, { cookieless: true })
+    zenovayReady = true
+  }
+
+  afterNavigate(({ from }) => {
+    if (zenovayReady && from) {
+      page()
+    }
+  })
 </script>
 
 {#if $navigating}

+PUBLIC_ZENOVAY_TRACKING_CODE=''
 PRIVATE_SUPABASE_SERVICE_ROLE='REPLACE_ME'
 
 # Stripe settings
@@ -13,4 +16,4 @@ PRIVATE_STRIPE_API_KEY='REPLACE_ME'

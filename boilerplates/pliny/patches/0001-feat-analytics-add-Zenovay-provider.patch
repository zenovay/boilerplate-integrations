--- /dev/null
+++ b/packages/pliny/src/analytics/Zenovay.tsx
@@ -0,0 +1,48 @@
+'use client'
+
+import { usePathname, useSearchParams } from 'next/navigation'
+import Script from 'next/script.js'
+import { useEffect, useRef } from 'react'
+
+export interface ZenovayProps {
+  trackingCode: string
+  cookieless?: boolean
+  src?: string
+}
+
+export const Zenovay = ({
+  trackingCode,
+  cookieless = true,
+  src = 'https://api.zenovay.com/z.js',
+}: ZenovayProps) => {
+  const pathname = usePathname()
+  const searchParams = useSearchParams()
+  const previousUrl = useRef<string>()
+
+  useEffect(() => {
+    const query = searchParams.toString()
+    const currentUrl = `${pathname}${query ? `?${query}` : ''}`
+
+    if (!previousUrl.current) {
+      previousUrl.current = currentUrl
+      return
+    }
+
+    if (previousUrl.current === currentUrl) {
+      return
+    }
+
+    previousUrl.current = currentUrl
+    window.zenovay?.('page')
+  }, [pathname, searchParams])
+
+  return (
+    <Script
+      id="zenovay-script"
+      strategy="afterInteractive"
+      data-id={trackingCode}
+      data-cookieless={cookieless ? 'true' : undefined}
+      src={src}
+    />
+  )
+}

diff --git a/app/zenovay-provider.tsx b/app/zenovay-provider.tsx
new file mode 100644
index 0000000..7b25d9e
--- /dev/null
+++ b/app/zenovay-provider.tsx
@@ -0,0 +1,42 @@
+'use client';
+
+import { init, page } from '@zenovay/tracker';
+import { usePathname, useSearchParams } from 'next/navigation';
+import { useEffect, useRef } from 'react';
+
+export function ZenovayProvider() {
+  const pathname = usePathname();
+  const searchParams = useSearchParams();
+  const previousUrl = useRef<string | undefined>(undefined);
+
+  useEffect(() => {
+    const trackingCode = process.env.NEXT_PUBLIC_ZENOVAY_TRACKING_CODE;
+
+    if (!trackingCode) {
+      return;
+    }
+
+    init(trackingCode, { cookieless: true });
+    const query = searchParams.toString();
+    previousUrl.current = `${pathname}${query ? `?${query}` : ''}`;
+  }, []);
+
+  useEffect(() => {
+    const query = searchParams.toString();
+    const currentUrl = `${pathname}${query ? `?${query}` : ''}`;
+
+    if (!previousUrl.current) {
+      previousUrl.current = currentUrl;
+      return;
+    }
+
+    if (previousUrl.current === currentUrl) {
+      return;
+    }
+
+    previousUrl.current = currentUrl;
+    page();
+  }, [pathname, searchParams]);
+
+  return null;
+}

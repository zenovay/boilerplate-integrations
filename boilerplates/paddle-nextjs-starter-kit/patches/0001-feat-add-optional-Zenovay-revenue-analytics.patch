diff --git a/src/components/analytics/zenovay-provider.tsx b/src/components/analytics/zenovay-provider.tsx
new file mode 100644
index 0000000..e43f305
--- /dev/null
+++ b/src/components/analytics/zenovay-provider.tsx
@@ -0,0 +1,42 @@
+'use client';
+
+import { init, page } from '@zenovay/tracker';
+import { usePathname } from 'next/navigation';
+import { useEffect, useRef } from 'react';
+
+export function ZenovayProvider() {
+  const pathname = usePathname();
+  const initialized = useRef(false);
+  const previousPath = useRef<string | null>(null);
+
+  useEffect(() => {
+    const trackingCode = process.env.NEXT_PUBLIC_ZENOVAY_TRACKING_CODE;
+
+    if (!trackingCode) return;
+
+    // Default mode uses Zenovay's persistent first-party visitor ID so the
+    // checkout page and the post-payment /checkout/success redirect resolve to
+    // the same visitor. If you enable cookieless mode for this website in the
+    // Zenovay dashboard, you may pass { cookieless: true } here as well —
+    // the client flag alone creates window-scoped IDs that break cross-page
+    // attribution when the server-side setting is off.
+    init(trackingCode);
+    initialized.current = true;
+  }, []);
+
+  useEffect(() => {
+    if (!initialized.current) return;
+
+    if (previousPath.current === null) {
+      previousPath.current = pathname;
+      return;
+    }
+
+    if (previousPath.current !== pathname) {
+      previousPath.current = pathname;
+      page();
+    }
+  }, [pathname]);
+
+  return null;
+}

+// Identify as soon as Paddle knows the customer (email entered), not only on
+// checkout.completed — Paddle redirects to the success URL immediately after
+// completion, so a completed-only identify can be cancelled by the redirect.
+// Browser events are IDENTIFICATION ONLY; revenue is recorded exclusively from
+// Paddle's signed transaction.completed webhook.
+const identityEvents = new Set(['checkout.customer.created', 'checkout.customer.updated', 'checkout.completed']);
+
+// Read the Zenovay visitor id from the loaded tracker (undefined while the
+// tracker script is still loading). Passed to Paddle as
+// customData.zenovay_attribution_id so the signed webhook can attribute the
+// purchase to this visitor even if no browser event ever fires.
+function getZenovayVisitorId(): string | undefined {
+  if (typeof window === 'undefined') return undefined;
+  const zenovay = (window as { zenovay?: (...args: unknown[]) => unknown }).zenovay;
+  if (typeof zenovay !== 'function') return undefined;
+  try {
+    const id = zenovay('getVisitorId');
+    return typeof id === 'string' && id ? id : undefined;
+  } catch {
+    return undefined;
+  }
+}
